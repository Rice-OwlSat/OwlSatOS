{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "$comment": "All paths, compiler choice and board live in settings.cmake. Do NOT set PICO_SDK_PATH / PICO_TOOLCHAIN_PATH / PICO_BOARD here -- they would override settings.cmake via the environment/cache.",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "pico2-debug",
      "displayName": "Pico 2 Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "pico2-release",
      "displayName": "Pico 2 Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "pico2-debug",
      "configurePreset": "pico2-debug"
    },
    {
      "name": "pico2-release",
      "configurePreset": "pico2-release"
    }
  ]
}
